<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    
>
    <Dialog
        id="PM11TLDialog"
        title="{i18n>xtit.RTLDialogTitle}"
        class="sapUiResponsiveContentPadding" 
        resizable="true"
        draggable="true">
        <VBox id="idPM11TLVBox">

          <table:TreeTable
        id="treeTable"
        selectionMode="Single"
        enableColumnReordering="false"
       >

        <table:columns>

            <table:Column>
                <Label text="Object"/>
                <table:template>
                    <Text text="{ObjectExternalID}" wrapping="false" />
                </table:template>
            </table:Column>

           

            <table:Column>
                <Label text="Description"/>
                <table:template>
                    <Text text="{ObjectDescription}" wrapping="false" />
                </table:template>
            </table:Column>

              <!-- <table:Column>
                <Label text="HierarchyLevel"/>
                <table:template>
                    <Text text="{HierarchyLevel}" wrapping="false" />
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="NodeID"/>
                <table:template>
                    <Text text="{ObjectID}" wrapping="false" />
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="ParentNodeID"/>
                <table:template>
                    <Text text="{ParentObjectID}" wrapping="false" />
                </table:template>
            </table:Column>-->

           

        </table:columns>

    </table:TreeTable>
            
           
        </VBox>
        <beginButton>
            <Button
                id="idPM11TLButtonOK"
                text="{i18n>xbut.ok}"
                press="onPressSumbitPM11TaskList"
                type="Emphasized"
                enabled="{viewProperties>/bEnableRecommendedSelection}"
            />
        </beginButton>
        <endButton>
            <Button
                id="idPM11TLButtonClose"
                text="{i18n>xbut.close}"
                press="onPressClosePM11TaskList"
                type="Transparent"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
