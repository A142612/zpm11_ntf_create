<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
	<ResponsivePopover placement="Bottom" showHeader="true" id="RespPopoverCurrentNotifs" afterClose="onAfterClose"
		contentWidth="{= ${device>/system/phone} ? 'auto' : '35em'}" title="{i18n>xtit.similarWorkRequests}">
		<content>
			<List id="ListCurrentNotifications"
				items="{ path: '/xPM11x_MaintenanceNotification', suspended: true , sorter: [ { path: 'NotifProcessingPhase', descending: true } , { path: 'NotificationCreationDate', descending: true }, { path: 'NotificationCreationTime', descending: true }],
					parameters: {select: 'MaintenanceNotification,NotifProcessingPhase,NotificationCreationDate,NotificationCreationTime,NotificationText'}}"
				growing="true" growingThreshold="5" growingScrollToLoad="true">
				<items>
					<ObjectListItem id="CurrentWorkRequestId" icon="sap-icon://request" title="{MaintenanceNotification}" type="Navigation"
						press="onMNotificationItemPress">
						<firstStatus>
							<ObjectStatus id="CurrentWorkRequestStatus"
								text="{ path : 'NotifProcessingPhase' , formatter: '.formatter.formatWorkRequestStatus' }"></ObjectStatus>
						</firstStatus>
						<attributes>
							<ObjectAttribute id="CurrentWorkRequestNotificationText" text="{NotificationText}"/>
							<ObjectAttribute id="CurrentWorkRequestCreationDateTime"
								text="{ parts:[ { path: 'NotificationCreationDate' } , {path: 'NotificationCreationTime'} ], formatter: '.formatter.formatDateTimeToString' }"/>
						</attributes>
					</ObjectListItem>
				</items>
			</List>
		</content>
	</ResponsivePopover>
</core:FragmentDefinition>