<mvc:View controllerName="pm11.zpm11nftcreate.controller.CreateNotification" xmlns:mvc="sap.ui.core.mvc"
  displayBlock="true" xmlns="sap.m" xmlns:f="sap.ui.layout.form" xmlns:smartForm="sap.ui.comp.smartform" xmlns:native="sap.ndc"
	xmlns:smartField="sap.ui.comp.smartfield" xmlns:core="sap.ui.core" xmlns:semantic="sap.m.semantic" xmlns:layout="sap.ui.layout">
	<Page showHeader='false' id="createWorkRequestPage" floatingFooter="true">
		<content>
			<Panel id="createWrHigLevelPanel" headerText="{i18n>xtit.PageHeader}" class="removePanelBorder sapUiMediumPadding">
				<Panel id="createWrTechnicalDataPanel" headerText="{i18n>xtit.technicalData}" expandable="true" expanded="true">
					<HBox width="100%" id="messageStrip" class="messageStripWidth"
						visible="{= %{viewProperties>/currentWorkRequests} > 0 &amp;&amp; %{TechnicalObject} !== '' &amp;&amp; %{TechnicalObject} !== null &amp;&amp; %{TechObjIsEquipOrFuncnlLoc} !== '' }">
						<core:Fragment fragmentName="pm11.zpm11nftcreate.view.fragments.CurrentWorkRequestsWarning" type="XML"/>
					</HBox>
					<smartForm:SmartForm id="createWrSmartFormTechnical" editable="true" flexEnabled="false" class="formHiddenTitle">
						<smartForm:layout>
							<smartForm:Layout id="createWrSmartFormLayout" emptySpanL="3" emptySpanM="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"/>
						</smartForm:layout>
						<smartForm:Group id="createWrSmartGroupTechnicalData">
							<smartForm:GroupElement id="createWrSmartGroupElementTechnicalObject">
								<smartField:SmartField textInEditModeSource="ValueListNoValidation" id="createWrSmartFieldTechObj" placeholder="{i18n>xfld.technicalObject}"
									value="{TechnicalObjectLabel}" showSuggestion="true" showValueHelp="false" change=".onTechnicalObjectChanged">
									<smartField:layoutData>
										<layout:GridData id="createWrlayoutTechnicalObject" spanL="{= %{device>/system/desktop} ? 6 : 5 }"
											spanM="{= %{device>/system/desktop} ? 6 : 5 }" spanS="{= %{device>/system/desktop} ? 12 : 10 }"/>
									</smartField:layoutData>
								</smartField:SmartField>
								<native:BarcodeScannerButton id="createWrBarCodeScanner" provideFallback="false" scanSuccess=".onScanSuccess">
									<native:layoutData>
										<layout:GridData id="createWrLayoutBarCodeScanner" spanL="1" spanM="1" spanS="2"/>
									</native:layoutData>
								</native:BarcodeScannerButton>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementLocation" label="Functional Location" visible="{=%{TechObjIsEquipOrFuncnlLoc} === 'EAMS_EQUI'}">
								<Text id="createWrLocation"
									text="{ parts: [ { path:'SuperiorTechnicalObjectName' },{ path:'SuperiorTechnicalObjectLabel' },{path:'TechnicalObject'} ] , formatter:'.formatter._concatIdAndDescription' }"/>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElemntCurrentLocation">
								<smartField:SmartField id="customLocationFormInput" placeholder="{i18n>xfld.currentLocation}" value="{LocationDescription}"></smartField:SmartField>
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartGroupElementNotificationType">
								<smartField:SmartField id="createWrSmartFieldNotificationType" mandatory="true" clientSideMandatoryCheck="false" value="{NotificationType}" change=".onNotificationTypeChanged"
									placeholder="{i18n>xfld.NotificationType}"></smartField:SmartField>
							</smartForm:GroupElement>


							<smartForm:GroupElement id="createWrSmartGroupElementTitle">
								<smartField:SmartField id="createWrSmartFieldTitle" mandatory="true" clientSideMandatoryCheck="false" value="{ path: 'NotificationText'}"
									placeholder="{i18n>xfld.description}"></smartField:SmartField>
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrTextTemplateSmartGroupElement">
								<smartField:SmartField id="createWrTextTemplateSmartField" value="{WorkRequestTextTemplate}" change=".onLongtextTemplateChanged" editable="{longTextTemplates>/enabled}">
										<smartField:configuration>
											<smartField:Configuration id="createWrTextTemplateControlConfiguration" controlType="dropDownList"/>
										</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartGroupElementDescription" label="{MaintNotificationLongText/#@sap:label}">
								<smartField:SmartField id="createWrNotifLongText" width="100%" value="{MaintNotifLongTextForEdit}" placeholder="{i18n>xfld.description}"
									change=".onLongTextChanged"></smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementPriority" label='{MaintPriority/#@sap:label}'>
								<smartField:SmartField id="createWrPriorityField" value="{ path: 'MaintPriority' }" placeholder="{i18n>xfld.priority}" innerControlsCreated="._sortPriority" showValueHelp="false"
									change=".onPriorityChanged">
									<smartField:configuration>
										<smartField:Configuration id="createWrPriorityFieldControlConfiguration" controlType="dropDownList"/>
									</smartField:configuration>
								</smartField:SmartField>
								<!--<Button id="createWrButtonShowEPM" tooltip="{i18n>xbut.showEPM}" text="{i18n>xbut.showEPM}" press=".onShowEPM"
									enabled="{= %{MaintenancePlant} !== '' &amp;&amp; %{NotificationType} !== '' &amp;&amp; %{TechnicalObject} !== '' &amp;&amp; %{TechnicalObject} !== null &amp;&amp; %{TechObjIsEquipOrFuncnlLoc} !== '' }"/>-->
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartGroupElementTaskList" visible="{=!${viewProperties>/isPM11TaskListConfigured}}">
								<smartField:SmartField id="createWrSmartFieldTaskList" value="{TaskList}" textInEditModeSource="ValueListNoValidation" visible="{=!${viewProperties>/isPM11TaskListConfigured}}"/>
								<!--<Button id="createWrButtonRecommendedTaskList" tooltip="{i18n>xbut.GetRecommendedTaskLists}" text="{i18n>xbut.GetRecommendedTaskLists}" press=".onShowRecommendedTaskList"/>-->	
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartGroupElementPM11TaskList" visible="{viewProperties>/isPM11TaskListConfigured}" label="Task List">
								<Input id="createWrSmartFieldPM11TaskList" value="{TaskList}" showValueHelp="true" valueHelpRequest=".onTaskListValueHelpRequest" visible="{viewProperties>/isPM11TaskListConfigured}"/>
								<!--<Button id="createWrButtonRecommendedTaskList" tooltip="{i18n>xbut.GetRecommendedTaskLists}" text="{i18n>xbut.GetRecommendedTaskLists}" press=".onShowRecommendedTaskList"/>-->	
							</smartForm:GroupElement>

						
							
					
						</smartForm:Group>
					</smartForm:SmartForm>
				</Panel>
				<Panel id="createWrPanelGeneral" headerText="{i18n>xtit.genData}" expandable="true" expanded="true" visible="{= %{viewProperties>/referenceNotificationType} === 'M2' }">
					<!--<HBox width="100%" id="messageStripNotifProcessingContext" class="messageStripWidth"-->
					<!--	visible="{= %{MaintNotifProcessingContext} !== '' &amp;&amp; %{MaintNotifProcessingContext} !== null }">-->
					<!--	<core:Fragment id="notifProcessingCntxtFragment" fragmentName="pm11.eam.maintenanceworkrequest.creates1.view.fragments.NotificationProcessingContextWarning" type="XML"/>-->
					<!--</HBox>-->
                   
				   

					<smartForm:SmartForm id="createWrSmartFormGeneral" editable="true" flexEnabled="false">
						<smartForm:layout>
							<smartForm:Layout id="createWrSmartFormLayoutGeneral" emptySpanL="3" emptySpanM="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"/>
						</smartForm:layout>
						<smartForm:Group id="createWrSmartGroupGeneral">

						  <smartForm:GroupElement id="createWrSmartGroupElement">
								<smartField:SmartField id="createWrSmartFieldFailureModeGroup"  mandatory="true" clientSideMandatoryCheck="true" value="{MaintNotificationCodeGroup}" 
									placeholder="{i18n>xfld.FailureModeGroup}" change=".onFailureModeGroupChanged" >	
									<smartField:configuration>
										<smartField:Configuration id="createWrFailureModeGroupControlConfiguration" controlType="dropDownList" displayBehaviour="descriptionAndId"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>

						    
							<smartForm:GroupElement id="createWrSmartGroupElementFailureMode">
								<smartField:SmartField id="createWrSmartFieldFailureMode" mandatory="{viewProperties>/isISPMConfigured}" clientSideMandatoryCheck="true" value="{MaintNotificationCode}" placeholder="{i18n>xfld.failureMode}"
									change=".onFailureModeChanged">
									<smartField:configuration>
										<smartField:Configuration id="createWrFailureModeControlConfiguration" controlType="dropDownList" displayBehaviour="descriptionAndId"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>
							<!--<smartForm:GroupElement id="createWrSmartGroupElementDetectionCode" visible="{=!!${MaintNotifDetectionCatalog} }">
								<smartField:SmartField id="createWrSmartFieldDetectionCode" innerControlsCreated="._sortDetectionCodes" value="{MaintNotifDetectionCode}" change="_onDetectionCodeChanged">
									<smartField:configuration>
										<smartField:Configuration id="createWrDetectionCodeControlConfiguration" controlType="dropDownList"/>
									</smartField:configuration>
								</smartField:SmartField>
								<Text id="createWrFieldDetectionCodeGroup" text="{MaintNotifDetectionCodeGrpTxt}" enabled="true" editable="true">
									
								</Text>
								
							</smartForm:GroupElement>-->
							<smartForm:GroupElement id="createWrSmartGroupElementMalfunctionEffect">
								<smartField:SmartField id="createWrSmartFieldMalEffect" mandatory="{viewProperties>/isISPMConfigured}" clientSideMandatoryCheck="true" value="{MalfunctionEffect}" placeholder="{i18n>xfld.malEffect}"
									change=".onEffectChanged"></smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementBreakDown">
								<smartField:SmartField id="createWrSmartFieldBreakDown" value="{MaintenanceObjectIsDown}"/>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementMalfunctionStartDate">
								<smartField:SmartField id="createWrSmartFieldMalfunctionStartDateTime" value="{MalfunctionStartDateTime}"></smartField:SmartField>
							</smartForm:GroupElement>

                          
						   



							<!--<smartForm:GroupElement id="createWrSmartGroupElementNotifProcessingContext" visible="{=!!${MaintNotifProcgCntxtIsAllwd} }">
								<smartField:SmartField id="createWrSmartFieldNotifProcessingContext" value="{ path: 'MaintNotifProcessingContext' }" placeholder="{i18n>xfld.notifProcessingCntxt}" showValueHelp="false" change="_evaluateNotifProcessingContext">
									<smartField:configuration>
										<smartField:Configuration id="createWrNotifProcessingCntxtFieldControlConfiguration" controlType="dropDownList"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>-->

							<smartForm:GroupElement id="createWrSmartDetectionCodeGroup1">
								<smartField:SmartField id="createWrSmartFieldDetectionCodeGroup1" mandatory="{viewProperties>/isISPMConfigured}" value="{NewDetectionGroup}" 
									placeholder="{i18n>xfld.MaintNotifDetectionCodeGroup}" change=".onDetectionCodeGroupChanged" >
									
								</smartField:SmartField>
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartDetectionCode1">
								<smartField:SmartField id="createWrSmartFieldDetectionCode1" mandatory="{viewProperties>/isISPMConfigured}" value="{MaintNotifProcessSubPhaseCode}" 
									placeholder="{i18n>xfld.MaintNotifDetectionCode}" change=".onDetectionCodeChanged" >
									
								</smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementAtyText1">
								<smartField:SmartField id="createWrSmartFieldAtyText1"   value="{NewDetectionMethodText}"
									placeholder="{i18n>xfld.AtyText}"></smartField:SmartField>
							</smartForm:GroupElement>
							
							
							
							<!--
							<smartForm:GroupElement id="createWrSmartGroupElementMaintPlanningPlant" visible="{=${viewProperties>/emergencyNotification}}">
								<smartField:SmartField id="createWrSmartFieldMaintPlanningPlant" textInEditModeSource="ValueListNoValidation" mandatory="true" clientSideMandatoryCheck="false" value="{ path: 'MaintenancePlanningPlant'}"
									placeholder="{i18n>xfld.maintPlanPlant}"></smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementMaintOrderType" visible="{=${viewProperties>/emergencyNotification}}">
								<smartField:SmartField id="createWrSmartFieldMaintOrderType" clientSideMandatoryCheck="false" value="{ path: 'MaintenanceOrderType'}"
									placeholder="{i18n>xfld.orderType}" editable="false" enabled="false" >
									<smartField:configuration>
									<smartField:Configuration id="createWrOrderTypeFieldControlConfiguration" controlType="dropDownList" displayBehaviour="descriptionAndId"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>-->
							
							
							
						</smartForm:Group>
					</smartForm:SmartForm>


				</Panel>


            <Panel id="createWrPanelM1General" headerText="{i18n>xtit.requestMaint}" expandable="true" expanded="true" visible="{= %{viewProperties>/referenceNotificationType} === 'M1' }">
				<smartForm:SmartForm id="createWrSmartFormM1General" editable="true" flexEnabled="false">
						<smartForm:layout>
							<smartForm:Layout id="createWrSmartFormLayoutM1General" emptySpanL="3" emptySpanM="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"/>
						</smartForm:layout>
						<smartForm:Group id="createWrSmartGroupM1General">

						  <smartForm:GroupElement id="createWrSmartM1GroupElement" label="Coding Group" >
								<smartField:SmartField id="createWrSmartFieldM1FailureModeGroup"   value="{MaintNotificationCodeGroup}" 
									placeholder="{i18n>xfld.CodingGroup}"  >	
									<smartField:configuration>
										<smartField:Configuration id="createWrM1FailureModeGroupControlConfiguration" controlType="dropDownList" displayBehaviour="descriptionAndId"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>

						    
							<smartForm:GroupElement id="createWrSmartGroupElementM1FailureMode" label="Coding Code">
								<smartField:SmartField id="createWrSmartFieldM1FailureMode" value="{MaintNotificationCode}" placeholder="{i18n>xfld.CodingCode}"
									>
									<smartField:configuration>
										<smartField:Configuration id="createWrM1FailureModeControlConfiguration" controlType="dropDownList" displayBehaviour="descriptionAndId"/>
									</smartField:configuration>
								</smartField:SmartField>
							</smartForm:GroupElement>
						
						</smartForm:Group>
					</smartForm:SmartForm>


				</Panel>





				<Panel id="createWrPanelReponsibillities" headerText="{i18n>xtit.resp}" expandable="true" expanded="true">
					<smartForm:SmartForm id="createWrSmartFormResponsibilities" editable="true" flexEnabled="false">
						<smartForm:layout>
							<smartForm:Layout id="createWrSmartFormLayoutReponsibillities" emptySpanL="3" emptySpanM="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"/>
						</smartForm:layout>
						<smartForm:Group id="createWrSmartGroupResponsibillities">
							<smartForm:GroupElement id="createWrSmartGroupElementCreatedBy" label="{CreatedByUser/#@sap:label}">
								<Text id="createWrCreatedBy"
									text="{ parts: [ { path:'viewProperties>/createdByUserName' },{ path:'CreatedByUser' } ] , formatter:'.formatter._concatIdAndDescription' }"></Text>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementReportedBy">
								<smartField:SmartField textInEditModeSource="ValueListNoValidation" id="createWrSmartFieldReportedByUser" value="{ReportedByUser}" showValueHelp="true"></smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementReportedOn">
								<smartField:SmartField id="createWrSmartFieldReportedOnDateTime" value="{NotificationCreationDateTime}"></smartField:SmartField>
							</smartForm:GroupElement>

							<smartForm:GroupElement id="createWrSmartGroupElementMainWC" >
								<smartField:SmartField id="createWrSmartFieldMainWC" textInEditModeSource="ValueListNoValidation"  clientSideMandatoryCheck="false" value="{ path: 'MainWorkCenter'}"
									placeholder="{i18n>xfld.mainWrkCenter}"></smartField:SmartField>
							</smartForm:GroupElement>
							<smartForm:GroupElement id="createWrSmartGroupElementMainWCPlant">
								<smartField:SmartField id="createWrSmartFieldMainWCPlant" textInEditModeSource="ValueListNoValidation"  clientSideMandatoryCheck="false" value="{ path: 'MainWorkCenterPlant'}"
									></smartField:SmartField>
							</smartForm:GroupElement>
						</smartForm:Group>
					</smartForm:SmartForm>
				</Panel>
				<layout:VerticalLayout id="createWrVeritcalLayout" width="100%">
				  <core:ComponentContainer id="workRequestCreateAttachSrvCompContCreate" propagateModel="true" usage="attachmentReuseComponent"></core:ComponentContainer> 
				</layout:VerticalLayout>
			</Panel>
		</content>
		<footer>
			<OverflowToolbar id="createWrOverflowToolbar">
				<Button id="createWrMessageIndicator" text="{= ${message>/}.length }" visible="{=!!${message>/}.length}"
					icon="{ path: 'message>/', formatter: '.formatter.buttonIconFormatter' }"
					type="{ path: 'message>/', formatter: '.formatter.buttonTypeFormatter' }" enabled="true" press="onMessagesButtonPress"></Button>
				<DraftIndicator id="createWrDraftIndicator"></DraftIndicator>
				<ToolbarSpacer id="createWrOverflowToolbarSpacer"/>
				<Button id="createWrSubmitButton" tooltip="{i18n>xbut.submit}" text="{i18n>xbut.submit}" type="Emphasized" enabled="true" visible="true"
					press="onPressSave"/>
				<Button id="createMyDraftButton" tooltip="{i18n>xbut.myDrafts}" text="{i18n>xbut.myDrafts}" enabled="true" visible="true"
					press="onPressMyDraft"/>
				
				
				<Button id="createWrCancelButton" tooltip="{i18n>xbut.cancel}" text="{i18n>xbut.cancel}" press="onPressCancel"/>
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>